# Include documentation files
include README.md
include LICENSE
include CHANGELOG.md
include LIMITATIONS.md

# Include package configuration
include pyproject.toml
include setup.py

# Include examples
recursive-include examples *.py *.ipynb *.md

# Include package code
recursive-include tradestation *.py *.md *.json

# Include documentation
recursive-include docs *.md *.json

# Include test fixtures
recursive-include tests/fixtures *.py

# Exclude compiled Python files
global-exclude *.pyc
global-exclude *.pyo
global-exclude __pycache__

# Exclude development files
exclude .gitignore
exclude .env
exclude .env.example

# Exclude token files
exclude logs/tokens_*.json
